---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { isSafeHref } from '../lib/safe';

export interface Link { label: string; href: string }
export interface Props {
  variant?: 'poster' | 'wide' | 'photo' | 'row';
  // ImageMetadata (CMS upload / build-cached art) → optimized <Image> with srcset;
  // plain string (remote-URL fallback) → the old hotlinked <img>
  image?: string | ImageMetadata;
  kicker?: string;
  title: string;
  subtitle?: string;
  date?: Date;
  tags?: string[];
  rating?: number;
  status?: string;
  progress?: { show: boolean; value: number };
  links?: Link[];
}
const {
  variant = 'wide', image, kicker, title, subtitle, date,
  tags = [], rating, status, progress, links = [],
} = Astro.props;
// CMS/feed-supplied URLs — render only allowlisted schemes (see lib/safe)
const safeLinks = links.filter((l) => isSafeHref(l.href));

const ratio: Record<string, string> = {
  poster: '2 / 3', wide: '16 / 9', photo: '3 / 2', row: '',
};
// Candidate widths + honest `sizes` per grid variant. Track minimums come from
// app.css (.section__grid*: poster/compact 150px, photo 180px, wide 220px, lead 300px);
// tracks stretch to roughly 1.5–2×, and the top candidate covers 2× DPR.
const sizesFor: Record<string, string> = {
  poster: '(max-width: 480px) 46vw, 220px',
  photo: '(max-width: 480px) 46vw, 280px',
  wide: '(max-width: 760px) 92vw, 340px',
  row: '',
};
const widthsFor: Record<string, number[]> = {
  poster: [160, 240, 320, 480],
  photo: [200, 300, 420, 600],
  wide: [340, 520, 720, 1000],
  row: [],
};
// half-star aware: 2.5 → ★★½☆☆ (never rounds up)
const rated = rating != null && rating > 0;
const full = rated ? Math.floor(rating) : 0;
const half = rated && rating - full >= 0.5 ? 1 : 0;
const stars = rated ? '★'.repeat(full) + (half ? '½' : '') + '☆'.repeat(Math.max(0, 5 - full - half)) : null;
const dateStr = date
  ? new Intl.DateTimeFormat('en', { year: 'numeric', month: 'short' }).format(date)
  : null;
const metaBits = [dateStr, ...tags].filter(Boolean).join(' · ');
---
<article class={`card card--${variant}`}>
  {variant !== 'row' && (
    <div class="card__media" style={ratio ? `aspect-ratio:${ratio}` : undefined}>
      {typeof image === 'object' ? (
        <Image src={image} alt={title} widths={widthsFor[variant]} sizes={sizesFor[variant]} format="webp" loading="lazy" decoding="async" />
      ) : image ? (
        <img src={image} alt={title} loading="lazy" decoding="async" />
      ) : (
        <span class="card__ph">no image</span>
      )}
      {status && <span class="card__status">{status}</span>}
    </div>
  )}
  <div class="card__body">
    {kicker && <p class="card__kicker">{kicker}</p>}
    <h3 class="card__title">{title}</h3>
    {subtitle && <p class="card__sub">{subtitle}</p>}
    {stars && <p class="card__rating" aria-label={`${rating} out of 5`}>{stars}</p>}
    {progress?.show && (
      <div class="card__bar" role="progressbar" aria-valuenow={progress.value} aria-valuemin={0} aria-valuemax={100}>
        <i style={`width:${progress.value}%`}></i>
      </div>
    )}
    {metaBits && <p class="card__meta">{metaBits}</p>}
    {safeLinks.length > 0 && (
      <p class="card__links">{safeLinks.map((l) => <a href={l.href}>{l.label} ↗</a>)}</p>
    )}
  </div>
</article>

<style>
  .card { border: var(--hair) solid var(--ink); background: var(--bone); display: flex; flex-direction: column; }
  .card--row { flex-direction: row; align-items: baseline; gap: var(--space-3); border: 0; border-top: var(--hair) solid var(--line); padding: var(--space-3) 0; }
  .card__media { position: relative; border-bottom: var(--hair) solid var(--ink); display: flex; align-items: flex-end; overflow: hidden;
    background-image: repeating-linear-gradient(135deg, rgba(20, 19, 16, 0.06) 0 8px, transparent 8px 16px); }
  .card__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .card__ph { font-family: var(--font-mono); font-size: 10px; letter-spacing: 1px; color: var(--mut); padding: var(--space-2); text-transform: uppercase; }
  .card__status { position: absolute; top: 8px; right: 8px; font-family: var(--font-mono); font-size: 9px; letter-spacing: 1px; text-transform: uppercase; border: 1px solid var(--ink); padding: 1px 6px; background: var(--bone); }
  .card__body { padding: var(--space-3); display: flex; flex-direction: column; gap: 6px; }
  .card--row .card__body { padding: 0; }
  .card__kicker { font-family: var(--font-mono); font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--mut); margin: 0; }
  .card__title { font-family: var(--font-display); font-weight: 700; font-size: 18px; margin: 0; letter-spacing: 0.3px; }
  .card__sub { font-size: 13px; color: var(--mut); margin: 0; }
  .card__rating { color: var(--acc-ink); letter-spacing: 2px; margin: 0; }
  .card__bar { height: 6px; border: 1px solid var(--ink); }
  .card__bar i { display: block; height: 100%; background: var(--acc); }
  .card__meta { font-family: var(--font-mono); font-size: 10px; letter-spacing: 1px; color: var(--mut); margin: 0; text-transform: uppercase; }
  .card__links { display: flex; gap: 12px; margin: 2px 0 0; }
  .card__links a { font-family: var(--font-mono); font-size: 11px; color: var(--acc-ink); text-decoration: none; }
  .card__links a:hover { text-decoration: underline; }
</style>
