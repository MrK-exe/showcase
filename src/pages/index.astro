---
import Experience from '../layouts/Experience.astro';
import Section from '../components/Section.astro';
import type { Group } from '../components/Section.astro';
import RecordPlayer from '../components/RecordPlayer.astro';
import { sections, site, sources } from '../config/site.config';
import { getCollection } from 'astro:content';
import { getWriting, getFilms, getLastPlayed, getTopGames } from '../lib/data';
import { resolveArt } from '../lib/art';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/'); // guarantee trailing slash
const asset = (p?: string | null) => (!p ? undefined : /^https?:\/\//.test(p) ? p : base + p.replace(/^\//, ''));
const reveals = ['rise', 'flick', 'slide', 'glitch', 'rise', 'flick'];

// ── authored / uploaded collections (CMS) ──
const byDateDesc = (a: any, b: any) => +new Date(b.data.date ?? 0) - +new Date(a.data.date ?? 0);
const workEntries = (await getCollection('work')).sort(byDateDesc);
const photoEntries = (await getCollection('photos')).sort(byDateDesc);
const reviewEntries = (await getCollection('gameReviews')).sort(byDateDesc);

// ── fed data (pulled at build) + curated singletons ──
const writing = getWriting();
const films = getFilms();
const lastPlayed = getLastPlayed();
const topGames = getTopGames();

// Build the card groups for each section id. Every section uses the one Card primitive.
// Typed end-to-end: each card literal is checked against Card's Props (no `any` seam).
function groupsFor(id: string): Group[] {
  switch (id) {
    case 'work':
      return [{
        variant: 'row',
        cards: workEntries.slice(0, 5).map((e) => ({
          variant: 'row' as const, title: e.data.title, subtitle: e.data.summary, status: e.data.status,
          date: e.data.date, links: [{ label: 'Open', href: `${base}work/${e.id}` }],
        })),
      }];
    case 'writing':
      return [{
        variant: 'wide',
        cards: writing.slice(0, 4).map((w) => ({
          variant: 'wide' as const, image: resolveArt(w.image), title: w.title,
          date: w.date ? new Date(w.date) : undefined,
          links: [{ label: 'Read on Substack', href: w.link }],
        })),
      }];
    case 'photography':
      return [{
        variant: 'photo',
        cards: photoEntries.slice(0, 4).map((p) => ({
          variant: 'photo' as const, image: p.data.image, title: p.data.caption ?? '',
          date: p.data.date, links: p.data.instagramUrl ? [{ label: 'Instagram', href: p.data.instagramUrl }] : [],
        })),
      }];
    case 'films':
      return [
        {
          label: 'Favorites', variant: 'poster',
          cards: films.favorites.slice(0, 4).map((f) => ({
            variant: 'poster' as const, image: resolveArt(f.poster), title: f.title, rating: f.rating ?? undefined,
            links: f.link ? [{ label: 'Letterboxd', href: f.link }] : [],
          })),
        },
        {
          label: 'Recent reviews', variant: 'poster',
          cards: films.reviews.slice(0, 4).map((r) => ({
            variant: 'poster' as const, image: resolveArt(r.poster), title: r.title, subtitle: r.excerpt, rating: r.rating ?? undefined,
            date: r.watchedDate ? new Date(r.watchedDate) : undefined,
            links: r.link ? [{ label: 'Letterboxd', href: r.link }] : [],
          })),
        },
      ];
    case 'games':
      return [
        {
          label: 'Reviews', variant: 'poster',
          cards: reviewEntries.slice(0, 4).map((g) => ({
            variant: 'poster' as const, image: g.data.cover, title: g.data.title,
            subtitle: g.data.excerpt, rating: g.data.rating,
            links: [{ label: 'Read', href: `${base}games/${g.id}` }],
          })),
        },
        {
          label: 'Top 4', variant: 'poster',
          cards: topGames.slice(0, 4).map((g) => ({
            variant: 'poster' as const, image: resolveArt(g.cover), title: g.title,
            rating: g.rating != null ? Number(g.rating) : undefined,
          })),
        },
        {
          label: 'Steam · recently played', variant: 'poster',
          cards: lastPlayed.steam.slice(0, 4).map((g) => ({
            variant: 'poster' as const, image: resolveArt(g.cover), title: g.name, status: 'Steam',
            date: g.lastPlayed ? new Date(g.lastPlayed) : undefined,
          })),
        },
        {
          label: 'PlayStation · recently played', variant: 'poster',
          cards: lastPlayed.psn.slice(0, 4).map((g) => ({
            variant: 'poster' as const, image: resolveArt(g.cover), title: g.name, status: g.platform ?? 'PSN',
            date: g.lastPlayed ? new Date(g.lastPlayed) : undefined,
          })),
        },
      ];
    default:
      return [];
  }
}

const viewAll: Record<string, { href: string; label: string }> = {
  writing: { href: sources.substack, label: 'all on substack' },
  films: { href: `https://letterboxd.com/${sources.letterboxd}`, label: 'all on letterboxd' },
};
const emptyText: Record<string, string> = {
  work: 'No entries yet.',
  writing: 'No posts yet.',
  photography: 'No photos yet.',
  films: 'No films yet.',
  games: 'No games yet.',
};

const enabled = sections.filter((s) => s.enabled);
---
<Experience>
  <header class="hero" id="top">
    <p class="hero__kicker" data-scramble="periodic">{site.tagline}</p>
    <h1 class="hero__word" id="word" aria-label="Abdullah Aletai"><span id="word-t">ABDULLAH ALETAI</span><span class="hl">.</span></h1>

    {site.positioning && <p class="hero__positioning">{site.positioning}</p>}
    {site.bio && <p class="hero__bio">{site.bio}</p>}

    <div class="hero__cta">
      {/* real mailto link so contact works with JS off/failed; JS upgrades it to the connect modal */}
      <a class="btn btn--accent" href={`mailto:${site.email}`} data-open="connect-modal" data-mag aria-haspopup="dialog" aria-expanded="false">contact</a>
      {site.cvUrl && <a class="btn" href={asset(site.cvUrl)} data-mag>cv ↓</a>}
      {site.availability && <span class="hero__avail lab">{site.availability}</span>}
    </div>

    <nav class="hero__links" id="hero-links" aria-label="Jump to section">
      {enabled.map((s, i) => (
        <a href={`#${s.id}`} data-sectlink data-mag>
          <span class="hl-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span><span class="navlink__t" data-scramble="hover">{s.title}</span>
        </a>
      ))}
    </nav>

    <span class="hero__radar" id="hero-signal" aria-hidden="true">
      <span class="radar" id="hero-radar"></span>
    </span>

    <p class="hero__hint lab">↓ scroll</p>
  </header>

  {enabled.map((s, i) => {
    const num = String(i + 1).padStart(2, '0');
    if (s.component === 'RecordPlayer') {
      return <RecordPlayer num={num} id={s.id} title={s.title} meta={s.meta} weight={s.weight} />;
    }
    const va = viewAll[s.id];
    return (
      <Section
        num={num} id={s.id} title={s.title} meta={s.meta} weight={s.weight}
        reveal={reveals[i % reveals.length]}
        groups={groupsFor(s.id)}
        viewAllHref={va?.href} viewAllLabel={va?.label}
        empty={emptyText[s.id] ?? 'Nothing here yet.'}
      />
    );
  })}
</Experience>
