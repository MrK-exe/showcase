---
import '../styles/tokens.css';
import { site } from '../config/site.config';
interface Props { title?: string }
const { title = site.name } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={`${site.author} — ${site.tagline}`} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect x='50' y='6' width='62' height='62' transform='rotate(45 50 50)' fill='%23E5341C'/%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    <footer class="foot">© 2026 {site.name} · {site.url.replace('https://', '')} · built with Astro</footer>
  </body>
</html>

<style is:global>
  * { box-sizing: border-box; }
  body { margin: 0; background: var(--bone); color: var(--ink); font-family: var(--font-mono); font-size: 15px; line-height: 1.6; -webkit-font-smoothing: antialiased; }
  a { color: inherit; }
  .hero { min-height: 80vh; display: flex; flex-direction: column; justify-content: center; max-width: 1040px; margin: 0 auto; padding: 0 var(--space-4); border-bottom: 1.5px solid var(--ink); }
  .hero__kicker { font-family: var(--font-mono); font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--mut); margin: 0; }
  .hero__word { font-family: var(--font-display); font-weight: 700; font-size: clamp(40px, 9vw, 104px); line-height: 0.9; letter-spacing: 1px; margin: 10px 0; }
  .hero__word span { color: var(--acc); }
  .hero__tag { color: var(--mut); margin: 0; }
  .foot { max-width: 1040px; margin: 0 auto; padding: var(--space-5) var(--space-4) var(--space-6); font-family: var(--font-mono); font-size: 10px; letter-spacing: 1px; color: var(--mut); text-transform: uppercase; }
</style>
