# Build-time feed-pull secrets (optional locally — sections degrade to honest
# empty states without them). In CI these live in GitHub Actions secrets.

# Steam Web API key — https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# PSN npsso sign-in token — log in at playstation.com, then open
# https://ca.account.sony.com/api/v1/ssocookie and copy the value.
# Valid ~2 months; refresh when the PSN last-played list goes stale.
PSN_NPSSO=
